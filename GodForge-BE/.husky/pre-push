#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "Running backend pre-push validation..."

solution="GodForge.sln"

if [ ! -f "$solution" ]; then
  echo "$solution not found. Run ./scaffold.ps1 before enabling .NET pre-push validation."
  exit 0
fi

dotnet restore "$solution"
if [ $? -ne 0 ]; then
  echo "Restore failed."
  exit 1
fi

dotnet build "$solution" --no-restore
if [ $? -ne 0 ]; then
  echo "Build failed."
  exit 1
fi

dotnet test "$solution" --no-build
if [ $? -ne 0 ]; then
  echo "Tests failed."
  exit 1
fi

dotnet format "$solution" --verify-no-changes --no-restore
if [ $? -ne 0 ]; then
  echo "Format check failed."
  exit 1
fi

echo "Backend pre-push validation passed."
