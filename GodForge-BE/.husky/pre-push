#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "Running backend pre-push validation..."

npm run lint
if [ $? -ne 0 ]; then
  echo "Lint failed."
  exit 1
fi

npm run format:check
if [ $? -ne 0 ]; then
  echo "Format check failed."
  exit 1
fi

npm run typecheck
if [ $? -ne 0 ]; then
  echo "TypeScript check failed."
  exit 1
fi

npm run test:ci
if [ $? -ne 0 ]; then
  echo "Tests failed."
  exit 1
fi

npm run build
if [ $? -ne 0 ]; then
  echo "Build failed."
  exit 1
fi

echo "Backend pre-push validation passed."
