{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": "Host=localhost;Port=5432;Database=godforge;Username=godforge;Password=godforge_local_password",
        "Redis": "localhost:6379,abortConnect=false"
    },
    "RabbitMQ": {
        "Enabled": true,
        "HostName": "localhost",
        "Port": 5672,
        "UserName": "godforge",
        "Password": "godforge_local_password",
        "VirtualHost": "/"
    },
    "RepositoryProcessing": {
        "WorkspaceRoot": ".workspaces",
        "MaxRepositoryBytes": 524288000,
        "MaxTextFileBytes": 524288,
        "MaxContextCharacters": 1500000,
        "MaxFiles": 20000,
        "GitCommandTimeoutSeconds": 300
    },
    "Gemini": {
        "Enabled": false,
        "ApiKey": "",
        "Model": "gemini-2.5-flash",
        "Endpoint": "https://generativelanguage.googleapis.com",
        "TimeoutSeconds": 90,
        "MaxOutputTokens": 8192
    },
    "Forgejo": {
        "Enabled": false,
        "BaseUrl": "http://localhost:3000",
        "ApiToken": "",
        "WebhookSecret": "replace_with_random_secret"
    },
    "Jwt": {
        "Secret": "A_VERY_LONG_LOCAL_DEVELOPMENT_SECRET_KEY_CHANGE_ME_123456",
        "Issuer": "GodForge",
        "Audience": "GodForgeUsers",
        "ExpiryMinutes": 15
    }
}
