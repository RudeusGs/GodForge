# PostgreSQL
POSTGRES_USER=godforge
POSTGRES_PASSWORD=godforge_local_password
POSTGRES_DB=godforge
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_DEFAULT_USER=godforge
RABBITMQ_DEFAULT_PASS=godforge_local_password
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# MinIO
MINIO_ROOT_USER=godforge
MINIO_ROOT_PASSWORD=godforge_local_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Forgejo - internal hosted Git engine (optional until hosted repositories are enabled)
FORGEJO_HTTP_PORT=3000
FORGEJO_SSH_PORT=2222
FORGEJO_DB_NAME=forgejo
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=forgejo_local_password
FORGEJO_ADMIN_USER=godforge-admin
FORGEJO_ADMIN_PASSWORD=change_me_before_first_use
FORGEJO_ADMIN_EMAIL=admin@example.com

# Backend connection strings
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=godforge;Username=godforge;Password=godforge_local_password
ConnectionStrings__Redis=localhost:6379,abortConnect=false

# RabbitMQ application settings
RabbitMQ__Enabled=true
RabbitMQ__HostName=localhost
RabbitMQ__Port=5672
RabbitMQ__UserName=godforge
RabbitMQ__Password=godforge_local_password
RabbitMQ__VirtualHost=/

# Repository processing
RepositoryProcessing__WorkspaceRoot=.workspaces
RepositoryProcessing__MaxRepositoryBytes=524288000
RepositoryProcessing__MaxTextFileBytes=524288
RepositoryProcessing__MaxContextCharacters=1500000
RepositoryProcessing__MaxFiles=20000
RepositoryProcessing__GitCommandTimeoutSeconds=300
RepositoryProcessing__AllowPrivateNetworkRemotes=false
# Comma-separated binding is not portable; configure AllowedRemoteHosts in appsettings when needed.

# Gemini - server side only. Leave disabled until a valid API key is configured.
Gemini__Enabled=false
Gemini__ApiKey=
Gemini__Model=gemini-2.5-flash
Gemini__Endpoint=https://generativelanguage.googleapis.com
Gemini__TimeoutSeconds=90
Gemini__MaxOutputTokens=8192

# Forgejo adapter - server side only
Forgejo__Enabled=false
Forgejo__BaseUrl=http://localhost:3000
Forgejo__ApiToken=
Forgejo__WebhookSecret=replace_with_random_secret

# Email
Email__Smtp__Host=smtp.example.com
Email__Smtp__Port=587
Email__Smtp__EnableSsl=true
Email__Smtp__UserName=user@example.com
Email__Smtp__Password=password
Email__Smtp__FromEmail=user@example.com
Email__Smtp__FromName=GodForge

# JWT
Jwt__Secret=replace_with_at_least_32_random_characters
Jwt__Issuer=GodForge
Jwt__Audience=GodForgeUsers
Jwt__ExpiryMinutes=15

# Frontend URL used by backend emails
Frontend__BaseUrl=http://localhost:5173

# Frontend public API URL
VITE_API_BASE_URL=http://localhost:5072/api/v1

